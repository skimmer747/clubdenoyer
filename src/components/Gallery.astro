---
// Gallery tiles: optional `src` + `alt` use astro:assets <Image>; others stay gradient placeholders.
import { Image } from 'astro:assets';
import vegetableSpecial from '../assets/House Special with pepperoni.jpg';
import chickenWings from '../assets/Chicken Wings.jpg';

/** Widths passed to <Image> so Astro can generate srcset for sharp screens. */
const photoWidths = [400, 800, 1200] as const;
/** Rough column width in the responsive grid (matches minmax ~260px + breakpoints). */
const photoSizes = '(max-width: 720px) 100vw, 33vw';

const tiles = [
  {
    label: 'Vegetable Special with Pepperoni',
    tone: 'warm',
    src: vegetableSpecial,
    alt: 'Vegetable Special with Pepperoni at Club Denoyer',
  },
  {
    label: 'Chicken Wings',
    tone: 'amber',
    src: chickenWings,
    alt: 'Chicken wings at Club Denoyer',
  },
  { label: 'Dining room', tone: 'cream' },
  { label: 'Fresh dough', tone: 'olive' },
  { label: 'Old Fashioned', tone: 'rust' },
  { label: 'Northwoods evening', tone: 'smoke' },
] as const;
---
<section class="gallery" id="gallery">
  <div class="gallery__inner">
    <p class="section__eyebrow">A look around</p>
    <h2 class="section__title">The room, the food, the vibe.</h2>

    <div class="gallery__grid">
      {tiles.map((p) => (
        <figure class={`gallery__tile gallery__tile--${p.tone}`}>
          {'src' in p && p.src ? (
            <Image
              class="gallery__photo"
              src={p.src}
              alt={p.alt}
              widths={[...photoWidths]}
              sizes={photoSizes}
            />
          ) : null}
          <figcaption class="gallery__caption">{p.label}</figcaption>
        </figure>
      ))}
    </div>

    <p class="gallery__note">
      More photos coming soon — drop files into <code>src/assets/</code> and we will wire them up like the example photos.
    </p>
  </div>
</section>
