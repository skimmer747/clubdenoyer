---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import heroArt from '../assets/RAspainting.png';

const grain =
  'data:image/svg+xml;utf8,' +
  encodeURIComponent(
    '<svg xmlns="http://www.w3.org/2000/svg" width="240" height="240">' +
      '<filter id="n"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch"/></filter>' +
      '<rect width="100%" height="100%" filter="url(#n)" opacity="0.55"/>' +
    '</svg>'
  );
---
<section class="hero" id="top">
  <div class="hero__backdrop" aria-hidden="true">
    <Image
      src={heroArt}
      alt=""
      widths={[1200, 2000, 3000]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero__tint" aria-hidden="true"></div>
  <div class="hero__vignette" aria-hidden="true"></div>
  <div class="hero__grain" aria-hidden="true" style={`background-image:url("${grain}")`}></div>
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__content">
    <p class="hero__eyebrow">Eagle River · Wisconsin</p>
    <h1 class="hero__title">
      <span class="hero__title-line">Club</span>
      <span class="hero__title-line">Denoyer</span>
    </h1>
    <p class="hero__tagline">A Northwoods Bar serving &ldquo;Real&rdquo; Homemade Pizza</p>

    <div class="hero__actions">
      <a class="btn btn--primary" href="#menu">See the menu</a>
      <a class="btn btn--ghost" href={`tel:${site.phone.tel}`}>{site.phone.display}</a>
    </div>
  </div>

  <a class="hero__scroll" href="#about" aria-label="Scroll to about section">
    <span aria-hidden="true">&darr;</span>
  </a>
</section>
